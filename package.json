{
  "name": "steam-game-idler",
  "version": "0.1.0",
  "description": "Farm trading cards, manage achievements, and boost playtime effortlessly with Steam Game Idler",
  "author": "Autapomorph",
  "private": true,
  "workspaces": [
    "docs"
  ],
  "scripts": {
    "dev": "vite",
    "dev:docs": "npm run dev -w steam-game-idler-docs",
    "dev:all": "run-p tauri:dev dev:docs",
    "pub:docs": "npm run pub -w steam-game-idler-docs",
    "build": "tsc -b && vite build",
    "build:docs": "npm run build -w steam-game-idler-docs",
    "build:all": "run-s build build:docs",
    "start": "vite preview",
    "start:docs": "npm run start -w steam-game-idler-docs",
    "lint": "run-s -c typecheck lint:js",
    "lint:js": "eslint",
    "lint:docs": "npm run lint -w steam-game-idler-docs",
    "lint:all": "run-s -c lint lint:docs",
    "lint:staged": "lint-staged --relative",
    "typecheck": "tsc --noEmit -p ./tsconfig.app.json",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "prettier": "prettier --write .",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/unbounded": "^5.2.8",
    "@heroui/react": "^2.8.8",
    "@internationalized/date": "^3.12.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "~2.10.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "~2.7.0",
    "@tauri-apps/plugin-fs": "~2.5.0",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "@unhead/react": "^3.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "12.38.0",
    "geist": "^1.7.0",
    "github-markdown-css": "^5.9.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "mitt": "^3.0.1",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-i18next": "^17.0.5",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.2",
    "react-window": "^2.2.7",
    "tailwindcss": "^4.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.12",
    "prettier": "^3.8.3",
    "steiger": "^0.5.11",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-checker": "^0.13.0"
  }
}
